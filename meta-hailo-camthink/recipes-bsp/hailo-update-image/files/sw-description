software =
{
	version = "1.12.0"
	description = "Firmware update for Hailo SoC";
	hardware-compatibility: [ "1.0"];
	embedded-script = "
-- set default parameters
vars = {
    FILESYSTEM_DEVICE = '@@SWUPDATE_DEFAULT_FILESYSTEM_DEVICE@@',
    FIRMWARE_DEVICE = '@@SWUPDATE_DEFAULT_FIRMWARE_DEVICE@@',
    FW_ENV_DEVICE = '@@SWUPDATE_DEFAULT_FW_ENV_DEVICE@@'
}

-- override parameters with config file
local cfg = io.open('/tmp/swupdate.cfg', 'r')
if cfg then
	for line in cfg:lines() do
		local sep = line:find('=')
		if sep then
			vars[line:sub(1, sep - 1)] = line:sub(sep + 1)
		end
    end
    cfg:close()
end

-- formatting function to replace '${key}' with the parameter from vars[key]
function format(str)
	return (str:gsub('%${(.-)}', function(key)
		return vars[key]
	end))
end

-- hook functions for using templated fields
function format_device(elem)
	elem.device = format(elem.device)
	return true, elem
end

function format_data(elem)
	elem.data = format(elem.data)
	return true, elem
end

";
