		copy-a: {
			images: (
				{
					filename = "@@HAILO_TARGET@@-@@MACHINE@@.ext4.gz";
					device = "/dev/${FILESYSTEM_DEVICE}p2";
					hook = "format_device";
					installed-directly = true;
					compressed = "zlib";
				},
				{
					filename = "@@SCU_FW_BINARY_NAME@@";
					device = "/dev/${FIRMWARE_DEVICE}";
					hook = "format_device";
					offset = "0x8000";
