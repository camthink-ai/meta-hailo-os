diff --git a/include/configs/hailo15-ne503.h b/include/configs/hailo15-ne503.h
new file mode 100644
index 00000000..2afa8c8a
--- /dev/null
+++ b/include/configs/hailo15-ne503.h
@@ -0,0 +1,33 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Copyright (c) 2019-2023 Hailo Technologies Ltd. All rights reserved.  
+ *
+ * Configuration for Hailo15 NE503 (based on hailo15-sbc-rev3-1).
+ */
+
+#ifndef __HAILO15_NE503_H
+#define __HAILO15_NE503_H
+
+/* Kernel cmdline append: passed as default bootargs_board_options in hailo1x_common.h */
+#define BOARD_EXTRA_BOOTARGS "systemd.unified_cgroup_hierarchy=1"
+#define SWUPDATE_MMC_INDEX "1"
+#ifndef SPL_BOOT_SOURCE
+#define SPL_BOOT_SOURCE "nor"
+#endif
+
+#include "hailo15_common.h"
+
+/*! @note: lpddr4 inline ecc located at the top 1/8 of the referred CS.
+ *         In regards of using LPDDR4 setup of:
+ *           - 1 ranks (Also refered as CS)
+ *           - 2 channels per rank
+ *           - Each channel is 16 bits wide => each rank is 32 bits bide
+ *           - Rank size: 2G bytes
+ *         If __not__ using ECC, then memory access are located in a single region:
+ *           - 0x80000000 -  0xffffffff : Bank #0 (2G = 0x80000000)
+ *         If using ECC, then memory access are located in a single region:
+ *           - 0x080000000 - 0x0efffffff: Bank #0     (1.75G = 0x70000000)
+ *           - 0x0f0000000 - 0x0ffffffff: Bank #0 ECC (0.25G = 0x10000000)
+ */
+
+ #endif /* __HAILO15_NE503_H */
\ No newline at end of file
