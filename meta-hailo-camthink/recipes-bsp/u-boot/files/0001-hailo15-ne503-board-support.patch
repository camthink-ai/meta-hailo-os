diff --git a/arch/arm/dts/hailo15-ne503.dts b/arch/arm/dts/hailo15-ne503.dts
new file mode 100644
index 00000000..c0bbcaad
--- /dev/null
+++ b/arch/arm/dts/hailo15-ne503.dts
@@ -0,0 +1,85 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Hailo15 NE503 (based on hailo15-sbc), maintained in meta-hailo-os.
+ * Copyright (c) 2019-2023 Hailo Technologies Ltd. All rights reserved.
+ */
+
+#include "hailo15-base.dtsi"
+#include "hailo15_ddr_configuration.dtsi"
+#include "hailo1x_ddr_MT53E512M32D1-046_regconfig_2GB_LP4X.dtsi"
+
+&hailo_boot_info {
+    shutdown-gpio-pin = <20>;
+    ddr_config {
+        dram_auto_detect_en = <1>; // Warnning: Applicable only to Hailo15 SBC and must be removed otherwise.
+    };
+};
+
+&sdio0 {
+    status = "okay";
+    sdhci-caps = <0 0x01000000>; // Force VOLT33 capability
+    bus-width = <4>;
+    sd-vsel-gpio-pin = <17>; // GPIO for SD voltage select
+    sd-vsel-polarity-high;
+    phy-config {
+            card-is-emmc = <0x0>;
+            cmd-pad-values = <0x1 0x3 0x1 0x1>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            dat-pad-values = <0x1 0x3 0x1 0x1>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            rst-pad-values = <0x1 0x3 0x1 0x1>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            clk-pad-values = <0x1 0x3 0x0 0x1>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            sdclkdl-cnfg = <0x1 0x13>; //extdly_en, cckdl_dc
+            drive-strength = <0x8 0x4>; //pad_sp, pad_sn
+            u-boot,dm-spl;
+    };
+};
+&sdio1 {
+    status = "okay";
+    non-removable;
+    phy-config {
+            card-is-emmc = <0x1>;
+            cmd-pad-values = <0x2 0x2 0x1 0x1>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            dat-pad-values = <0x2 0x2 0x1 0x1>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            rst-pad-values = <0x2 0x2 0x1 0x1>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            clk-pad-values = <0x2 0x2 0x0 0x0>; // txslew_ctrl_n, txslew_ctrl_p, weakpull_enable, rxsel
+            sdclkdl-cnfg = <0x0 0x64>; //extdly_en, cckdl_dc
+            drive-strength = <0x9 0x8>; //pad_sp, pad_sn 
+            u-boot,dm-spl;   
+    };
+};
+
+/* AM20-01: RMII + LAN8720AI (PHY addr 0x02 per schematic) */
+&macb {
+	status = "okay";
+	phy-mode = "rmii";
+	phy-handle = <&phy0>;
+	pinctrl-names = "default";
+	pinctrl-0 = <&pinctrl_eth>;
+	mdio {
+		#address-cells = <1>;
+		#size-cells = <0>;
+		phy0: ethernet-phy@1 {
+			compatible = "ethernet-phy-id0007.c0f0";
+			reg = <1>;
+		};
+	};
+};
+
+&pinctrl {
+	pinctrl_eth: eth {
+		pins = "eth_rgmii_tx_clk",
+		       "eth_rgmii_tx_ctl",
+		       "eth_rgmii_txd_0",
+		       "eth_rgmii_txd_1",
+		       "eth_rgmii_txd_2",
+		       "eth_rgmii_txd_3";
+		drive-strength = <2>;
+	};
+};
+
+&i2c_0 {
+	status = "okay";
+};
+
+&i2c_1 {
+	status = "okay";
+};
